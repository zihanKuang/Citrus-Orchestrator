# LLM Configuration
GEMINI_API_KEY=your-gemini-api-key-here

# LLM Provider
LLM_PROVIDER=gemini

# Model Name
MODEL_NAME=gemini-2.5-flash

# Agent Settings
MAX_STEPS=10

# MCP tool call timeout (seconds)
TOOL_TIMEOUT_SECONDS=60

# Optional: override SRE system prompt (otherwise uses prompts.DEFAULT_SRE_SYSTEM_INSTRUCTION)
# AGENT_SYSTEM_INSTRUCTION=You are ...

# MCP Server Configuration
# Used when running the server locally (Agent CLI spawns it via stdio).

# Target namespace for all tools (also accepts NAMESPACE)
KUBERNETES_NAMESPACE=citrus

# Local default expects: kubectl port-forward -n citrus svc/monitoring-kube-prometheus-prometheus 9090:9090
# In-cluster Deployment sets this to the kube-prometheus Service DNS automatically.
PROMETHEUS_URL=http://localhost:9090

LOG_LEVEL=INFO

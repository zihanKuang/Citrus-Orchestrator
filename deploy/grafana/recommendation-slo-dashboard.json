{
  "dashboard": {
    "title": "Citrus Microservices - SLI/SLO Dashboard",
    "tags": ["citrus", "microservices", "slo"],
    "timezone": "browser",
    "editable": true,
    "graphTooltip": 1,
    "panels": [
      {
        "title": "SLO Status - Recommendation Service",
        "type": "stat",
        "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "(1 - (sum(rate(http_requests_total{job=\"recommendationservice\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"recommendationservice\"}[5m])))) * 100",
            "legendFormat": "Success Rate %",
            "refId": "A"
          }
        ],
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {"value": 0, "color": "red"},
            {"value": 99, "color": "yellow"},
            {"value": 99.9, "color": "green"}
          ]
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 99, "color": "yellow"},
                {"value": 99.9, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "title": "Request Rate (QPS)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{job=\"recommendationservice\"}[1m]))",
            "legendFormat": "Recommendations/sec",
            "refId": "A"
          },
          {
            "expr": "sum(rate(http_requests_total{job=\"frontend\"}[1m]))",
            "legendFormat": "Frontend/sec",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "reqps", "label": "Requests/sec"},
          {"format": "short"}
        ]
      },
      {
        "title": "P99 Latency - SLO: <200ms",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"recommendationservice\"}[5m])) by (le)) * 1000",
            "legendFormat": "P99 Latency",
            "refId": "A"
          },
          {
            "expr": "200",
            "legendFormat": "SLO Threshold (200ms)",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "ms", "label": "Latency"},
          {"format": "short"}
        ],
        "alert": {
          "name": "Recommendation Service P99 Latency High",
          "conditions": [
            {
              "evaluator": {"type": "gt", "params": [200]},
              "query": {"params": ["A", "5m", "now"]},
              "operator": {"type": "and"}
            }
          ],
          "frequency": "60s",
          "handler": 1,
          "message": "P99 latency exceeded 200ms SLO threshold",
          "noDataState": "keep_state",
          "executionErrorState": "keep_state"
        }
      },
      {
        "title": "Error Rate by Service",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (job) / sum(rate(http_requests_total[5m])) by (job) * 100",
            "legendFormat": "{{job}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "percent", "label": "Error Rate"},
          {"format": "short"}
        ]
      },
      {
        "title": "Pod Replica Count",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "count(kube_pod_info{namespace=\"citrus\"}) by (pod)",
            "legendFormat": "{{pod}}",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Memory Usage by Service",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
        "targets": [
          {
            "expr": "sum(container_memory_working_set_bytes{namespace=\"citrus\"}) by (pod) / 1024 / 1024",
            "legendFormat": "{{pod}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "mbytes", "label": "Memory"},
          {"format": "short"}
        ]
      },
      {
        "title": "CPU Usage by Service",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
        "targets": [
          {
            "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"citrus\"}[5m])) by (pod) * 1000",
            "legendFormat": "{{pod}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "percent", "label": "CPU %"},
          {"format": "short"}
        ]
      },
      {
        "title": "SLI Summary Table",
        "type": "table",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 28},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{job=\"recommendationservice\"}[5m]))",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "Value": "Request Rate (req/s)"
              }
            }
          }
        ]
      }
    ],
    "refresh": "10s",
    "time": {"from": "now-1h", "to": "now"},
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]
    },
    "annotations": {
      "list": [
        {
          "datasource": "Prometheus",
          "enable": true,
          "expr": "ALERTS{alertstate=\"firing\",namespace=\"citrus\"}",
          "iconColor": "red",
          "name": "Alerts",
          "step": "60s",
          "tagKeys": "alertname",
          "textFormat": "{{alertname}}",
          "titleFormat": "Alert"
        }
      ]
    }
  },
  "overwrite": true
}
